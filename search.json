---
layout: none
---
[
  {%- for release in site.data.search_index.releases %}
  {
    "title"    : "{{ release.title | escape }}",
    "category" : "Release",
    "url"      : "{{ site.baseurl }}{{ release.url }}",
    "date"     : "{{ release.date }}"
  }{% unless forloop.last %},{% endunless %}
  {%- endfor %}
  {%- if site.data.search_index.shows.size > 0 %},{% endif %}
  {%- for show in site.data.search_index.shows %}
  {
    "title"    : "{{ show.title | escape }}",
    "category" : "Show",
    "url"      : "{{ site.baseurl }}{{ show.url }}",
    "date"     : ""
  }{% unless forloop.last %},{% endunless %}
  {%- endfor %}
  {%- if site.data.search_index.tracks.size > 0 %},{% endif %}
  {%- for track in site.data.search_index.tracks %}
  {
    "title"    : "{{ track.title | escape }}",
    "category" : "Track",
    "url"      : "{{ site.baseurl }}{{ track.url }}",
    "date"     : ""
  }{% unless forloop.last %},{% endunless %}
  {%- endfor %}
]
